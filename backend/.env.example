# Django Settings
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
# ALLOWED_HOSTS: Add your LAN IP for mobile/LAN testing (find with: ipconfig getifaddr en0 or ifconfig)
# Example: ALLOWED_HOSTS=localhost,127.0.0.1,192.168.1.100,testserver
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,10.0.0.119

# Database (PostgreSQL)
# Defaults below are local Docker. To switch to AWS RDS for development,
# run: ./infra/configure-env.sh
# That script populates POSTGRES_HOST/PORT/DB/USER/PASSWORD from terraform
# outputs + Secrets Manager, and sets POSTGRES_SSLMODE=require.
POSTGRES_DB=chatpop
POSTGRES_USER=chatpop_user
POSTGRES_PASSWORD=chatpop_pass
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
# "prefer" works for local; configure-env.sh sets "require" for RDS.
POSTGRES_SSLMODE=prefer

# Redis
REDIS_HOST=localhost
REDIS_PORT=6381

# Django Server
DJANGO_PORT=9000

# CORS Settings
# Add your LAN IP URLs for mobile/LAN testing (both http and https)
# Example with LAN IP 192.168.1.100:
# CORS_ALLOWED_ORIGINS=http://localhost:4000,https://localhost:4000,http://192.168.1.100:4000,https://192.168.1.100:4000
CORS_ALLOWED_ORIGINS=http://localhost:4000,https://localhost:4000

# ngrok Settings (for external testing via ngrok tunnel)
# Set your ngrok static domain to enable external access (without https:// prefix)
# Get your free static domain from: https://dashboard.ngrok.com/cloud-edge/domains
# Example: NGROK_DOMAIN=your-subdomain.ngrok-free.app
NGROK_DOMAIN=

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Media Storage (AWS S3)
# Leave AWS_STORAGE_BUCKET_NAME empty for local filesystem storage.
# Set it (and AWS_PROFILE / AWS_LOCATION) for S3.
# Credentials come from boto3's default chain: env vars, AWS_PROFILE, or
# (in production) the EC2 instance role. Static keys are intentionally NOT
# read from .env — keep admin keys in ~/.aws/credentials, not the project.
AWS_PROFILE=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_LOCATION=
AWS_S3_CUSTOM_DOMAIN=
# If using CloudFront, set custom domain (e.g., d111111abcdef8.cloudfront.net)

# OpenAI (Media Analysis - Photos)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Media Analysis Performance Tracking
# Enable detailed performance logging for media analysis pipeline (disabled by default)
# Set to True to track LLM API calls, database queries, and processing steps
MEDIA_ANALYSIS_PERFORMANCE_TRACKING=False

# SerpAPI (Reverse Image Search)
SERPAPI_API_KEY=your-serpapi-key-here

# ACRCloud (Audio Recognition - Music Identification)
ACRCLOUD_ACCESS_KEY=your-acrcloud-access-key-here
ACRCLOUD_SECRET_KEY=your-acrcloud-secret-key-here
ACRCLOUD_HOST=identify-us-west-2.acrcloud.com
# ACRCloud Metadata API Bearer Token (for fetching genres, album art, streaming links)
# Get from: https://console.acrcloud.com/avr#/account/api-keys
ACRCLOUD_BEARER_TOKEN=your-acrcloud-bearer-token-here

# Google Places API (Location Suggestions)
# Enable Places API in Google Cloud Console: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
GOOGLE_PLACES_API_KEY=your-google-places-api-key-here

# TomTom API (Alternative Location Provider)
# Get API key from: https://developer.tomtom.com/
# Configure provider via Django Admin > Constance > PLACES_PROVIDER
TOMTOM_API_KEY=your-tomtom-api-key-here

# Cloudflare
# TODO: Add Cloudflare WAF (paid, $20/mo) when at scale for DDoS and network-layer bot protection.
# Turnstile (below) handles application-layer bot detection. WAF complements it at the network layer.
#
# Turnstile (bot detection)
# Leave empty to disable (no-op in development).
# To test, set BOTH frontend site key and backend secret key:
#   Frontend (NEXT_PUBLIC_TURNSTILE_SITE_KEY in frontend/.env.local):
#     1x00000000000000000000AA  — always passes invisibly
#     2x00000000000000000000AB  — always blocks (test error handling)
#     3x00000000000000000000FF  — always shows interactive challenge (test UI)
#   Backend (below):
#     1x0000000000000000000000000000000AA  — always accepts (use with any test site key)
#     2x0000000000000000000000000000000AA  — always rejects (test backend 403 error handling)
#     3x0000000000000000000000000000000AA  — returns "token already spent" error
CLOUDFLARE_TURNSTILE_SECRET_KEY=
