#!/usr/bin/env bash
# post-checkout — fires after `git checkout` and `git switch`.
#
# Switches the cloud DB / S3 prefix to match the current branch.
# - On branch creation: clones <dev>_main → <dev>_<branch> on RDS, syncs S3.
# - On switching to existing branch: just updates .env to point there.
# - On file checkouts and detached HEAD: skips silently.
#
# Args: $1=prev_sha  $2=new_sha  $3=branch_checkout (1=branch, 0=file)

set -euo pipefail

# 1. Skip file-level checkouts (e.g., `git checkout -- foo.py`).
[[ "${3:-0}" == "1" ]] || exit 0

# 2. Skip detached HEAD (no symbolic ref).
git symbolic-ref --short HEAD >/dev/null 2>&1 || exit 0

REPO_ROOT=$(git rev-parse --show-toplevel)
ENV_FILE="${REPO_ROOT}/backend/.env"
IDENTITY_FILE="${REPO_ROOT}/.dev-identity"

# 3. Skip if cloud mode isn't configured (new clones, local-only setups).
[[ -f "$ENV_FILE" ]] || exit 0
grep -q "^AWS_PROFILE=chatpop" "$ENV_FILE" 2>/dev/null || exit 0
[[ -f "$IDENTITY_FILE" ]] || exit 0

# 4. Compare current branch's expected DB name vs what's in .env.
DEV_NAME=$(cat "$IDENTITY_FILE")
BRANCH=$(git symbolic-ref --short HEAD)
BRANCH_SAFE=$(python3 -c '
import re, sys
s = sys.argv[1].lower()
s = re.sub(r"[^a-z0-9_]", "_", s)
s = re.sub(r"_+", "_", s)
print(s.strip("_"))
' "$BRANCH")
EXPECTED_DB="${DEV_NAME}_${BRANCH_SAFE}"
CURRENT_DB=$(grep "^POSTGRES_DB=" "$ENV_FILE" | head -1 | cut -d= -f2-)

# Already aligned — nothing to do.
[[ "$CURRENT_DB" == "$EXPECTED_DB" ]] && exit 0

printf "\n\033[1;34m[post-checkout]\033[0m branch '%s' → DB '%s'\n" "$BRANCH" "$EXPECTED_DB"

# 5. Run the configure script — it idempotently creates DB+S3 prefix if needed.
"$REPO_ROOT/infra/configure-env.sh" "$DEV_NAME"

# 6. Kill any running Daphne so the next request reads the new env.
# Filter to LISTEN sockets only (excludes the frontend's outbound connection
# to port 9000, which would otherwise also match).
if PID=$(lsof -ti:9000 -sTCP:LISTEN 2>/dev/null | head -1); then
  if [[ -n "$PID" ]] && kill "$PID" 2>/dev/null; then
    printf "\033[1;33m[post-checkout]\033[0m Killed Daphne (PID %s). Restart to pick up new DB:\n" "$PID"
    printf "  cd backend && ./venv/bin/daphne -e ssl:9000:privateKey=../certs/localhost+3-key.pem:certKey=../certs/localhost+3.pem -b 0.0.0.0 chatpop.asgi:application\n\n"
  fi
fi
