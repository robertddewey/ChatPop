#!/usr/bin/env bash
# post-merge — fires after `git merge` and `git pull`.
#
# If new migration files appeared in the merge, runs `migrate` against the
# current branch's DB so the schema stays in sync with code.
#
# Skips silently when:
#   - cloud mode isn't configured
#   - no migration files changed in the merge

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
ENV_FILE="${REPO_ROOT}/backend/.env"

[[ -f "$ENV_FILE" ]] || exit 0
grep -q "^AWS_PROFILE=chatpop" "$ENV_FILE" 2>/dev/null || exit 0

# ORIG_HEAD is set by git to the previous HEAD before the merge.
# If unavailable, skip — we have nothing to compare against.
git rev-parse --verify ORIG_HEAD >/dev/null 2>&1 || exit 0

CHANGED_MIGRATIONS=$(git diff --name-only ORIG_HEAD HEAD -- 'backend/*/migrations/*.py')
CHANGED_FIXTURES=$(git diff --name-only ORIG_HEAD HEAD -- 'fixtures/*.json')

# Fast exit if nothing relevant changed.
[[ -z "$CHANGED_MIGRATIONS" && -z "$CHANGED_FIXTURES" ]] && exit 0

cd "$REPO_ROOT/backend"

# Apply schema changes first.
if [[ -n "$CHANGED_MIGRATIONS" ]]; then
  COUNT=$(echo "$CHANGED_MIGRATIONS" | wc -l | tr -d ' ')
  printf "\n\033[1;34m[post-merge]\033[0m %s migration file(s) changed; running migrate\n" "$COUNT"
  ./venv/bin/python manage.py migrate --no-input
fi

# Then load any updated reference fixtures (themes, gifts, constance).
if [[ -n "$CHANGED_FIXTURES" ]]; then
  COUNT=$(echo "$CHANGED_FIXTURES" | wc -l | tr -d ' ')
  printf "\n\033[1;34m[post-merge]\033[0m %s fixture file(s) changed; running loaddata\n" "$COUNT"
  while IFS= read -r fixture; do
    [[ -f "$REPO_ROOT/$fixture" ]] || continue
    printf "  → %s\n" "$fixture"
    ./venv/bin/python manage.py loaddata "$REPO_ROOT/$fixture" 2>&1 | tail -1
  done <<< "$CHANGED_FIXTURES"
fi

# Hint about replace-main when a feature branch has just been merged into main.
# Detection: we're on main AND HEAD is a merge commit AND the second parent is
# reachable as a known feature branch. Non-destructive — just a printed hint.
CURRENT_BRANCH=$(git -C "$REPO_ROOT" symbolic-ref --short HEAD 2>/dev/null || echo "")
if [[ "$CURRENT_BRANCH" == "main" ]]; then
  # `git rev-parse HEAD^@` lists parent SHAs (one per line).
  PARENTS=$(git -C "$REPO_ROOT" rev-parse HEAD^@ 2>/dev/null || echo "")
  PARENT_COUNT=$(echo "$PARENTS" | wc -l | tr -d ' ')
  if [[ "$PARENT_COUNT" -ge 2 ]]; then
    SECOND_PARENT=$(echo "$PARENTS" | sed -n '2p')
    # Try to identify the branch that was merged via the second parent.
    MERGED_BRANCH=$(git -C "$REPO_ROOT" name-rev --name-only --refs='refs/heads/*' "$SECOND_PARENT" 2>/dev/null | sed 's|^refs/heads/||;s|~.*||;s|\^.*||')
    if [[ -n "$MERGED_BRANCH" && "$MERGED_BRANCH" != "main" && "$MERGED_BRANCH" != "undefined" ]]; then
      printf "\n\033[1;33m[post-merge hint]\033[0m Detected merge of '%s' into main.\n" "$MERGED_BRANCH"
      printf "  To carry that branch's DB and S3 data forward into <dev>_main, run:\n"
      printf "    \033[1mchatpop replace-main %s\033[0m\n" "$MERGED_BRANCH"
      printf "  (Skip if you don't need the branch's test data — just keep working on main.)\n\n"
    fi
  fi
fi
