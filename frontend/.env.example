# Backend API URL (use https for SSL)
NEXT_PUBLIC_API_URL=https://localhost:9000

# WebSocket URL (use wss for secure websockets)
NEXT_PUBLIC_WS_URL=wss://localhost:9000

# Frontend server port (MUST be 4000 per project standards)
PORT=4000

# Stripe Publishable Key (test mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Environment (development, production)
NODE_ENV=development

# Cloudflare
# TODO: Add Cloudflare WAF (paid, $20/mo) when at scale for DDoS and network-layer bot protection.
# Turnstile (below) handles application-layer bot detection. WAF complements it at the network layer.
#
# Turnstile (bot detection)
# Leave empty to disable (no-op in development).
# Test site keys (pair with backend secret 1x0000000000000000000000000000000AA):
#   1x00000000000000000000AA  — always passes invisibly
#   2x00000000000000000000AB  — always blocks (test error handling)
#   3x00000000000000000000FF  — always shows interactive challenge (test UI)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
